# =============================================================================
# GovQL environment variables — copy to .env and fill in secrets.
# Secrets (POSTGRES_PASSWORD) are encrypted with dotenvx in the real .env;
# store the decryption key in .env.keys (gitignored).
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER="govql"
POSTGRES_PASSWORD="changeme"           # encrypt with: dotenvx set POSTGRES_PASSWORD <value>
POSTGRES_DB="govql-data"

# Constructed from the above — used by the server and ingester.
# dotenvx interpolates ${VAR} references at runtime.
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}"

# ---------------------------------------------------------------------------
# Redis  (rate limiting)
# ---------------------------------------------------------------------------
# When running via Docker Compose, the service name "redis" is the hostname.
# For a managed Redis (e.g. Upstash, Railway), replace with the full URL.
REDIS_URL="redis://redis:6379"

# ---------------------------------------------------------------------------
# API server
# ---------------------------------------------------------------------------
# Set to "true" to enable GraphiQL in the browser (development only).
ENABLE_GRAPHIQL="false"

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL="info"
