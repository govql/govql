# Source container environment so HEALTHCHECK_* and DATABASE_URL vars are available.
# Job output is sent to PID 1's stdout/stderr (cron -f) so it flows to the
# container's logs → Vector → Loki, like every other service.
#
# After a successful scrape, advance the source's `fetch` cursor in source_state
# (write-fetch-cursor.sh) — the producer side of the fetch→load handshake. The
# cursor write is chained with && so it runs only on scrape success, and the
# healthcheck fires only after the cursor write succeeds.
SHELL=/bin/sh

35 * * * * root . /etc/environment; cd /congress && /usr/local/bin/usc-run votes --force > /proc/1/fd/1 2>/proc/1/fd/2 && /usr/local/bin/write-fetch-cursor.sh congress-votes > /proc/1/fd/1 2>/proc/1/fd/2 && { [ -n "$HEALTHCHECK_VOTES_SCRAPE_URL" ] && curl -fsS --retry 3 "$HEALTHCHECK_VOTES_SCRAPE_URL" > /dev/null 2>&1; }; true
0  2 * * * root /usr/local/bin/update-legislators.sh > /proc/1/fd/1 2>/proc/1/fd/2
